<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>GPU VRAM Estimator • ScopedLabs</title>
  <link rel="stylesheet" href="/assets/style.css?v=compute-gpu-003" />

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    window.SL_SUPABASE_URL = "https://ybnzjtuecirzajraddft.supabase.co";
    window.SL_SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...";
  </script>
  <script defer src="/assets/auth.js?v=0402"></script>
  <script defer src="/assets/app.js?v=0402"></script>
</head>

<body data-tier="pro" data-category="compute" data-step="gpu-vram" data-lane="v1">

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-dot"></span>
      <span class="brand-text">ScopedLabs</span>
    </a>

    <nav class="site-nav">
      <a class="nav-pill" href="/">Home</a>
      <a class="nav-pill" href="/tools/">Tools</a>
      <a class="nav-pill" href="/tools/compute/">Compute</a>
    </nav>
  </div>
</header>

<main class="container page">

  <div class="crumbs">
    <a href="/tools/">Tools</a>
    <span class="sep">/</span>
    <a href="/tools/compute/">Compute</a>
    <span class="sep">/</span>
    <span>GPU VRAM</span>
  </div>

  <h1>GPU VRAM Estimator</h1>

  <div id="pipeline"></div>

  <p class="subhead">
    Estimate GPU memory requirements — or confirm GPU is not needed.
  </p>

  <div id="flow-note" class="card" style="display:none;"></div>

  <section class="card">
    <p class="tool-best-for">
      <strong>Best for:</strong> AI / ML / rendering workloads — or confirming CPU-only systems.
    </p>
  </section>

  <section class="card tool-card">
    <h2>Workload Mode</h2>

    <div class="form-grid">
      <label class="field">
        <span class="label">GPU Required?</span>
        <select id="gpuMode">
          <option value="no" selected>No (CPU-only)</option>
          <option value="yes">Yes (AI / GPU workload)</option>
        </select>
      </label>
    </div>
  </section>

  <section class="card tool-card">
    <h2>Inputs</h2>

    <div class="form-grid">
      <label class="field">
        <span class="label">Model Size (GB)</span>
        <input id="modelGb" type="number" value="8" min="0" step="0.1" />
      </label>

      <label class="field">
        <span class="label">Batch Size</span>
        <input id="batch" type="number" value="4" min="1" step="1" />
      </label>

      <label class="field">
        <span class="label">VRAM per Sample (MB)</span>
        <input id="perSampleMb" type="number" value="200" min="0" step="1" />
      </label>

      <label class="field">
        <span class="label">Concurrent Jobs</span>
        <input id="jobs" type="number" value="2" min="1" step="1" />
      </label>

      <label class="field">
        <span class="label">Overhead (%)</span>
        <input id="overhead" type="number" value="20" min="0" max="300" step="0.1" />
      </label>
    </div>

    <div class="actions">
      <button id="calc" class="btn btn-primary">Calculate</button>
      <button id="reset" class="btn">Reset</button>
    </div>
  </section>

  <section class="card tool-card">
    <h2>Results</h2>
    <div id="results"><div class="muted">Run calculation.</div></div>
    <div id="analysis-copy" style="display:none;"></div>
  </section>

  <div id="continue-wrap" class="card" style="display:none;">
    <button id="continue" class="btn btn-primary" disabled>
      Continue → Power & Thermal
    </button>
  </div>

</main>

<script src="/assets/tool-flow.js"></script>
<script src="/assets/catalog.js"></script>
<script src="/assets/pipelines.js"></script>
<script src="/assets/pipeline.js"></script>
<script src="/assets/analyzer.js"></script>
<script src="./script.js?v=003"></script>

</body>
</html>






