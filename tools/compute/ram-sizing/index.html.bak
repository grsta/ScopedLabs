  <script defer src="/assets/auth.js?v=0405"></script>
  <script defer src="/assets/app.js?v=0405"></script>

  <style>
    .results-copy {
      display: grid;
      gap: 12px;
      margin-top: 14px;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: fit-content;
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.04);
      font-size: .92rem;
      font-weight: 600;
      letter-spacing: .02em;
    }

    .status-pill.healthy { color: #b6f7cb; }
    .status-pill.watch { color: #ffe39a; }
    .status-pill.risk { color: #ffb0b0; }

    .analysis-note {
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 16px;
      padding: 14px;
      background: rgba(255,255,255,.025);
    }

    .analysis-note strong {
      display: block;
      margin-bottom: 6px;
    }
  </style>
</head>

<body data-tier="free" data-category="compute" data-step="ram-sizing" data-lane="v1">
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/">
        <span class="brand-dot"></span>
        <span class="brand-text">ScopedLabs</span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        <a class="nav-pill" href="/">Home</a>
        <a class="nav-pill" href="/tools/">Tools</a>
        <a class="nav-pill" href="/tools/compute/">Compute</a>
      </nav>
    </div>
  </header>

  <main class="container page">
    <div class="crumbs">
      <a href="/tools/">Tools</a>
      <span class="sep">/</span>
      <a href="/tools/compute/">Compute</a>
      <span class="sep">/</span>
      <span>RAM Sizing</span>
    </div>

    <h1>RAM Sizing Estimator</h1>

    <div id="pipeline"></div>

    <p class="subhead">Estimate system memory based on workload type, concurrency, and cache needs.</p>

    <div id="flow-note" class="card" style="display:none;"></div>

    <section class="card">
      <p class="tool-best-for">
        <strong>Best for:</strong> validating memory requirements and detecting memory pressure after CPU sizing.
      </p>
    </section>

    <section class="card tool-card">
      <h2>Inputs</h2>

      <div class="form-grid">
        <label class="field">
          <span class="label">Workload Type</span>
          <select id="workload">
            <option value="general" selected>General / Mixed</option>
            <option value="web">Web / API</option>
            <option value="db">Database</option>
            <option value="virtualization">Virtualization</option>
            <option value="analytics">Analytics / ML</option>
          </select>
        </label>

        <label class="field">
          <span class="label">Concurrent Processes / VMs</span>
          <input id="concurrency" type="number" min="1" step="1" value="10" />
        </label>

        <label class="field">
          <span class="label">Avg RAM per Process (GB)</span>
          <input id="perProc" type="number" min="0" step="0.1" value="2" />
        </label>

        <label class="field">
          <span class="label">OS / Base Overhead (GB)</span>
          <input id="osGb" type="number" min="0" step="0.5" value="8" />
        </label>

        <label class="field">
          <span class="label">Cache / Headroom (%)</span>
          <input id="headroom" type="number" min="0" step="1" value="25" />
        </label>
      </div>

      <div class="actions">
        <button id="calc" class="btn btn-primary">Calculate</button>
        <button id="reset" class="btn">Reset</button>
      </div>
    </section>

    <section class="card tool-card">
      <h2>Results</h2>
      <div id="results" class="results">
        <div class="muted">Enter values and press Calculate.</div>
      </div>
      <div id="analysis-copy" class="results-copy" style="display:none;"></div>
    </section>

    <div id="continue-wrap" class="card" style="display:none;">
      <button id="continue" class="btn btn-primary" disabled>
        Continue → Storage IOPS
      </button>
    </div>
  </main>

  <script src="/assets/tool-flow.js"></script>
  <script src="/assets/catalog.js"></script>
  <script src="/assets/pipelines.js"></script>
  <script src="/assets/pipeline.js"></script>
  <script src="/assets/analyzer.js"></script>
  <script src="./script.js?v=007"></script>
</body>
</html>






