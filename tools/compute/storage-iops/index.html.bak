  <script defer src="/assets/auth.js?v=0403"></script>
  <script defer src="/assets/app.js?v=0403"></script>
</head>

<body data-tier="free" data-category="compute" data-step="storage-iops" data-lane="v1">
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="/">
        <span class="brand-dot"></span>
        <span class="brand-text">ScopedLabs</span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        <a class="nav-pill" href="/">Home</a>
        <a class="nav-pill" href="/tools/">Tools</a>
        <a class="nav-pill" href="/tools/compute/">Compute</a>
      </nav>
    </div>
  </header>

  <main class="container page">
    <div class="crumbs">
      <a href="/tools/">Tools</a>
      <span class="sep">/</span>
      <a href="/tools/compute/">Compute</a>
      <span class="sep">/</span>
      <span>Storage IOPS</span>
    </div>

    <h1>Storage IOPS Estimator</h1>

    <div id="pipeline"></div>

    <p class="subhead">Estimate read/write IOPS required for your workload and identify storage pressure early.</p>

    <div id="flow-note" class="card" style="display:none;"></div>

    <section class="card">
      <p class="tool-best-for">
        <strong>Best for:</strong> checking whether your workload is likely to become storage-limited after CPU and RAM sizing are established.
      </p>
    </section>

    <section class="card tool-card">
      <h2>Inputs</h2>

      <div class="form-grid">
        <label class="field">
          <span class="label">Transactions per Second</span>
          <input id="tps" type="number" min="0" step="1" value="2000" />
        </label>

        <label class="field">
          <span class="label">Reads per Transaction</span>
          <input id="reads" type="number" min="0" step="1" value="2" />
        </label>

        <label class="field">
          <span class="label">Writes per Transaction</span>
          <input id="writes" type="number" min="0" step="1" value="1" />
        </label>

        <label class="field">
          <span class="label">RAID Write Penalty</span>
          <select id="penalty">
            <option value="1">None / JBOD</option>
            <option value="2">RAID 1 / 10 (×2)</option>
            <option value="4" selected>RAID 5 (×4)</option>
            <option value="6">RAID 6 (×6)</option>
          </select>
        </label>

        <label class="field">
          <span class="label">Headroom (%)</span>
          <input id="headroom" type="number" min="0" step="1" value="30" />
        </label>
      </div>

      <div class="actions">
        <button id="calc" class="btn btn-primary">Calculate</button>
        <button id="reset" class="btn">Reset</button>
      </div>
    </section>

    <section class="card tool-card">
      <h2>Results</h2>
      <div id="results" class="results">
        <div class="muted">Enter values and press Calculate.</div>
      </div>
      <div id="analysis-copy" style="display:none;"></div>
    </section>

    <div id="continue-wrap" class="card" style="display:none;">
      <button id="continue" class="btn btn-primary" disabled>
        Continue → Storage Throughput
      </button>
    </div>
  </main>

  <script src="/assets/tool-flow.js"></script>
  <script src="/assets/catalog.js"></script>
  <script src="/assets/pipelines.js"></script>
  <script src="/assets/pipeline.js"></script>
  <script src="/assets/analyzer.js"></script>
  <script src="./script.js?v=004"></script>
</body>
</html>



