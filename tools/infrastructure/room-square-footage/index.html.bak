<body data-tier="pro" data-category="infrastructure" data-step="room-square-footage" data-lane="v1">
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-dot"></span>
      <span class="brand-text">ScopedLabs</span>
    </a>
    <nav class="site-nav">
      <a class="nav-pill" href="/">Home</a>
      <a class="nav-pill" href="/tools/">Tools</a>
      <a class="nav-pill" href="/tools/infrastructure/">Infrastructure</a>
    </nav>
  </div>
</header>

<main class="container page">
  <div class="crumbs">
    <a href="/tools/">Tools</a>
    <span class="sep">/</span>
    <a href="/tools/infrastructure/">Infrastructure</a>
    <span class="sep">/</span>
    <span>Room Square Footage</span>
  </div>

  <h1>Room Square Footage Planner</h1>

  <div id="pipeline"></div>

  <p class="subhead">
    Estimate room size from equipment footprint, clearance needs, and growth reserve before rack layout begins.
  </p>

  <div id="flow-note" class="card" style="display:none;"></div>

  <section class="card">
    <p class="tool-best-for">
      <strong>Best for:</strong> setting a realistic room-size baseline before rack, aisle, and infrastructure planning starts.
    </p>
  </section>

  <section class="card tool-card">
    <h2>Inputs</h2>

    <div class="form-grid">
      <label class="field">
        <span class="label">Equipment Footprint (sq ft)</span>
        <input id="equip" type="number" min="1" step="1" value="250">
      </label>

      <label class="field">
        <span class="label">Clearance / Aisle Factor (x)</span>
        <input id="factor" type="number" min="1" step="0.1" value="2.0">
      </label>

      <label class="field">
        <span class="label">Growth Reserve (%)</span>
        <input id="growth" type="number" min="0" step="1" value="20">
      </label>
    </div>

    <div class="actions">
      <button id="calc" class="btn btn-primary">Calculate</button>
      <button id="reset" class="btn">Reset</button>
    </div>
  </section>

  <section class="card tool-card">
    <h2>Results</h2>
    <div id="results" class="results">
      <div class="muted">Enter values and press Calculate.</div>
    </div>
    <div id="analysis-copy" style="display:none;"></div>
  </section>

  <div id="continue-wrap" class="card" style="display:none;">
    <button id="continue" class="btn btn-primary" disabled>
      Continue → Rack RU Planner
    </button>
  </div>
</main>

<script src="/assets/tool-flow.js"></script>
<script src="/assets/catalog.js"></script>
<script src="/assets/pipelines.js"></script>
<script src="/assets/pipeline.js"></script>
<script src="/assets/analyzer.js"></script>
<script src="./script.js?v=003"></script>
</body>
</html>



