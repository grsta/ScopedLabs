<body data-tier="pro" data-category="performance" data-tool="latency-vs-throughput" data-step="latency-vs-throughput" data-lane="v1">

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-dot"></span>
      <span class="brand-text">ScopedLabs</span>
    </a>
    <nav class="site-nav">
      <a class="nav-pill" href="/">Home</a>
      <a class="nav-pill" href="/tools/">Tools</a>
      <a class="nav-pill" href="/tools/performance/">Performance</a>
    </nav>
  </div>
</header>

<main class="container page">
  <div class="crumbs">
    <a href="/tools/">Tools</a> /
    <a href="/tools/performance/">Performance</a> /
    Latency vs Throughput
  </div>

  <h1>Latency vs Throughput Estimator</h1>

  <div id="pipeline"></div>

  <p class="subhead">Understand how latency increases as system utilization approaches capacity.</p>

  <div id="flow-note" class="card" style="display:none;"></div>

  <section class="card">
    <p class="tool-best-for">
      <strong>Best for:</strong> visualizing how close your system is to saturation and how quickly latency will degrade as throughput rises toward capacity.
    </p>
  </section>

  <section class="card tool-card">
    <h2>Inputs</h2>

    <div class="form-grid">
      <label class="field">
        <span class="label">Base Latency (ms)</span>
        <input id="baseLat" type="number" min="0" step="0.1" value="25">
      </label>

      <label class="field">
        <span class="label">Current Throughput</span>
        <input id="t0" type="number" min="0" step="1" value="1200">
      </label>

      <label class="field">
        <span class="label">Target Throughput</span>
        <input id="t1" type="number" min="0" step="1" value="1800">
      </label>

      <label class="field">
        <span class="label">System Capacity</span>
        <input id="cap" type="number" min="0.1" step="1" value="2000">
      </label>
    </div>

    <div class="actions">
      <button id="calc" class="btn btn-primary" type="button">Calculate</button>
      <button id="reset" class="btn" type="button">Reset</button>
    </div>
  </section>

  <section class="card tool-card">
    <h2>Results</h2>
    <div id="results" class="results">
      <div class="muted">Enter values and press Calculate.</div>
    </div>
    <div id="analysis-copy" style="display:none;"></div>
  </section>

  <div id="continue-wrap" class="card" style="display:none;">
    <button id="continue" class="btn btn-primary" disabled>
      Continue → Queue Depth
    </button>
  </div>
</main>

<script src="/assets/tool-flow.js?v=perf-latency-throughput-0404"></script>
<script src="/assets/catalog.js?v=perf-latency-throughput-0404"></script>
<script src="/assets/pipelines.js?v=perf-latency-throughput-0404"></script>
<script src="/assets/pipeline.js?v=perf-latency-throughput-0404"></script>
<script src="/assets/analyzer.js?v=perf-latency-throughput-0404"></script>
<script src="./script.js?v=perf-latency-throughput-0404"></script>

</body>
</html>





