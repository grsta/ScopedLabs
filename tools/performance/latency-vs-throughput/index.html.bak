<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Latency vs Throughput Estimator *ScopedLabs</title>
  <meta
    name="description"
    content="Estimate how latency accelerates as throughput approaches system capacity and identify when the load curve becomes dangerous."
  />

  <link rel="stylesheet" href="/assets/style.css?v=perf-latency-throughput-0404" />

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
