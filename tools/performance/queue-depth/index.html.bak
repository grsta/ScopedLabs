<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Queue Depth Estimator *ScopedLabs</title>
  <meta
    name="description"
    content="Estimate backlog formation, queue pressure, and response-time growth from arrival rate, service rate, and worker count."
  />

  <link rel="stylesheet" href="/assets/style.css?v=perf-queue-depth-0404" />

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    window.SL_SUPABASE_URL = "https://ybnzjtuecirzajraddft.supabase.co";
    window.SL_SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlibnpqdHVlY2lyemFqcmFkZGZ0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA1ODYwNjEsImV4cCI6MjA4NjE2MjA2MX0.502bvCMrfbdJV9yXcHgjJx_t6eVcTVc0AlqxIbb9AAM";
  </script>

  <script defer src="/assets/auth.js?v=perf-queue-depth-0404"></script>
  <script defer src="/assets/app.js?v=perf-queue-depth-0404"></script>
</head>

<body data-tier="pro" data-category="performance" data-tool="queue-depth" data-step="queue-depth" data-lane="v1">

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-dot"></span>
      <span class="brand-text">ScopedLabs</span>
    </a>
    <nav class="site-nav">
      <a class="nav-pill" href="/">Home</a>
      <a class="nav-pill" href="/tools/">Tools</a>
      <a class="nav-pill" href="/tools/performance/">Performance</a>
    </nav>
  </div>
</header>

<main class="container page">
  <div class="crumbs">
    <a href="/tools/">Tools</a> /
    <a href="/tools/performance/">Performance</a> /
    Queue Depth
  </div>

  <h1>Queue Depth Estimator</h1>

  <div id="pipeline"></div>

  <p class="subhead">Estimate queue depth from arrival rate and service rate.</p>

  <div id="flow-note" class="card" style="display:none;"></div>

  <section class="card">
    <p class="tool-best-for">
      <strong>Best for:</strong> identifying backlog formation and where latency begins to accumulate under load.
    </p>
  </section>

  <section class="card tool-card">
    <h2>Inputs</h2>

    <div class="form-grid">
      <label class="field">
        <span class="label">Arrival Rate (req/s)</span>
        <input id="lambda" type="number" min="0" step="1" value="900">
      </label>

      <label class="field">
        <span class="label">Service Rate (req/s)</span>
        <input id="mu" type="number" min="0.1" step="1" value="1200">
      </label>

      <label class="field">
        <span class="label">Servers / Workers</span>
        <input id="k" type="number" min="1" step="1" value="1">
      </label>

      <label class="field">
        <span class="label">Base Service Time (ms)</span>
        <input id="svc" type="number" min="0" step="0.1" value="4">
      </label>
    </div>

    <div class="actions">
      <button id="calc" class="btn btn-primary" type="button">Calculate</button>
      <button id="reset" class="btn" type="button">Reset</button>
    </div>
  </section>

  <section class="card tool-card">
    <h2>Results</h2>
    <div id="results" class="results">
      <div class="muted">Enter values and press Calculate.</div>
    </div>
    <div id="analysis-copy" style="display:none;"></div>
  </section>

  <div id="continue-wrap" class="card" style="display:none;">
    <button id="continue" class="btn btn-primary" disabled>
      Continue → Concurrency Scaling
    </button>
  </div>
</main>

<script src="/assets/tool-flow.js?v=perf-queue-depth-0404"></script>
<script src="/assets/catalog.js?v=perf-queue-depth-0404"></script>
<script src="/assets/pipelines.js?v=perf-queue-depth-0404"></script>
<script src="/assets/pipeline.js?v=perf-queue-depth-0404"></script>
<script src="/assets/analyzer.js?v=perf-queue-depth-0404"></script>
<script src="./script.js?v=perf-queue-depth-0404"></script>

</body>
</html>




