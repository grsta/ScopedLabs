<body data-tier="free" data-category="thermal" data-step="btu-converter" data-lane="v1">

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-dot"></span>
      <span class="brand-text">ScopedLabs</span>
    </a>
    <nav class="site-nav">
      <a class="nav-pill" href="/">Home</a>
      <a class="nav-pill" href="/tools/">Tools</a>
      <a class="nav-pill" href="/tools/thermal/">Thermal</a>
    </nav>
  </div>
</header>

<main class="container page">
  <div class="crumbs">
    <a href="/tools/">Tools</a> /
    <a href="/tools/thermal/">Thermal</a> /
    BTU Converter
  </div>

  <h1>BTU Converter</h1>

  <div id="pipeline"></div>

  <p class="subhead">Convert between Watts, BTU/hr, and Tons of Cooling.</p>

  <div id="flow-note" class="card" style="display:none;"></div>

  <section class="card">
    <p class="tool-best-for">
      <strong>Best for:</strong> translating electrical heat load into HVAC sizing units for airflow and cooling calculations downstream.
    </p>
  </section>

  <section class="card tool-card">
    <h2>Inputs</h2>

    <div class="form-grid">
      <label class="field">
        <span class="label">Watts (W)</span>
        <input id="w" type="number" value="3500">
      </label>

      <label class="field">
        <span class="label">BTU/hr</span>
        <input id="btu" type="number" value="11942">
      </label>

      <label class="field">
        <span class="label">Tons (cooling)</span>
        <input id="tons" type="number" step="0.01" value="1.00">
      </label>

      <label class="field">
        <span class="label">Edit Mode</span>
        <select id="mode">
          <option value="watts" selected>Watts → BTU/hr → Tons</option>
          <option value="btu">BTU/hr → Watts → Tons</option>
          <option value="tons">Tons → BTU/hr → Watts</option>
        </select>
      </label>
    </div>

    <div class="actions">
      <button id="calc" class="btn btn-primary">Convert</button>
      <button id="reset" class="btn">Reset</button>
    </div>
  </section>

  <section class="card tool-card">
    <h2>Results</h2>
    <div id="results" class="results">
      <div class="muted">Enter values and press Convert.</div>
    </div>
  </section>

  <section id="analysis-copy" class="card tool-card" style="display:none;"></section>

  <div id="continue-wrap" class="card" style="display:none;">
    <button id="continue" class="btn btn-primary" disabled>
      Continue → Rack Density
    </button>
  </div>
</main>

<script src="/assets/tool-flow.js"></script>
<script src="/assets/catalog.js"></script>
<script src="/assets/pipelines.js"></script>
<script src="/assets/pipeline.js"></script>
<script src="/assets/analyzer.js"></script>
<script src="./script.js?v=003"></script>

</body>
</html>





