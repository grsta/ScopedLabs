  <script defer src="/assets/auth.js?v=0407"></script>
  <script defer src="/assets/app.js?v=0407"></script>
</head>

<body data-tier="pro" data-category="wireless" data-step="ap-capacity" data-lane="v1">

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-dot"></span>
      <span class="brand-text">ScopedLabs</span>
    </a>
    <nav class="site-nav">
      <a class="nav-pill" href="/">Home</a>
      <a class="nav-pill" href="/tools/">Tools</a>
      <a class="nav-pill" href="/tools/wireless/">Wireless</a>
    </nav>
  </div>
</header>

<main class="container page">
  <div class="crumbs">
    <a href="/tools/">Tools</a> /
    <a href="/tools/wireless/">Wireless</a> /
    AP Capacity
  </div>

  <h1>AP Capacity Planner</h1>

  <div id="pipeline"></div>

  <p class="subhead">Estimate AP count from client load and throughput targets (planning-level).</p>

  <div id="flow-note" class="card" style="display:none;"></div>

  <section class="card">
    <p class="tool-best-for">
      <strong>Best for:</strong> sizing AP count by comparing bandwidth demand against client-density limits so you can see which constraint fails first.
    </p>
  </section>

  <section class="card tool-card">
    <h2>Inputs</h2>

    <div class="form-grid">
      <label class="field">
        <span class="label">Total Clients</span>
        <input id="clients" type="number" value="150">
      </label>

      <label class="field">
        <span class="label">Avg Throughput per Client (Mbps)</span>
        <input id="mbps" type="number" step="0.1" value="3">
      </label>

      <label class="field">
        <span class="label">Target Utilization (%)</span>
        <input id="util" type="number" value="60">
      </label>

      <label class="field">
        <span class="label">Effective AP Capacity (Mbps)</span>
        <input id="apcap" type="number" value="300">
      </label>

      <label class="field">
        <span class="label">Max Clients per AP</span>
        <input id="maxc" type="number" value="35">
      </label>
    </div>

    <div class="actions">
      <button id="calc" class="btn btn-primary" type="button">Calculate</button>
      <button id="reset" class="btn" type="button">Reset</button>
      <a class="btn" href="/tools/wireless/">← Back to Wireless</a>
    </div>
  </section>

  <section class="card tool-card">
    <h2>Results</h2>
    <div id="results" class="results">
      <div class="muted">Enter values and press Calculate.</div>
    </div>
  </section>

  <section id="analysis-copy" class="card tool-card" style="display:none;"></section>

  <div id="continue-wrap" class="card" style="display:none;">
    <button id="continue" class="btn btn-primary" disabled type="button">
      Continue → Link Budget
    </button>
  </div>
</main>

<script src="/assets/tool-flow.js"></script>
<script src="/assets/catalog.js"></script>
<script src="/assets/pipelines.js"></script>
<script src="/assets/pipeline.js"></script>
<script src="/assets/analyzer.js"></script>
<script src="./script.js?v=003"></script>

</body>
</html>



