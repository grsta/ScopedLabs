<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Noise Floor Margin *ScopedLabs</title>

  <link rel="stylesheet" href="/assets/style.css?v=vs-raid-pro-0191" />

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script>
    window.SL_SUPABASE_URL = "https://ybnzjtuecirzajraddft.supabase.co";
    window.SL_SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJIUzI1NiIsInR5cCI6IkpXVCJ9";
  </script>

  <script defer src="/assets/auth.js?v=0410"></script>
  <script defer src="/assets/app.js?v=0410"></script>
</head>

<body data-tier="pro" data-category="wireless" data-step="noise-floor-margin" data-lane="v1">

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-dot"></span>
      <span class="brand-text">ScopedLabs</span>
    </a>
    <nav class="site-nav">
      <a class="nav-pill" href="/">Home</a>
      <a class="nav-pill" href="/tools/">Tools</a>
      <a class="nav-pill" href="/tools/wireless/">Wireless</a>
    </nav>
  </div>
</header>

<main class="container page">
  <div class="crumbs">
    <a href="/tools/">Tools</a> /
    <a href="/tools/wireless/">Wireless</a> /
    Noise Floor Margin
  </div>

  <h1>Noise Floor Margin</h1>

  <div id="pipeline"></div>

  <p class="subhead">Calculate SNR (signal-to-noise ratio) and margin vs a target SNR.</p>

  <div id="flow-note" class="card" style="display:none;"></div>

  <section class="card">
    <p class="tool-best-for">
      <strong>Best for:</strong> validating whether the RF environment has enough margin to support stable client service before you size client density and AP loading.
    </p>
  </section>

  <section class="card tool-card">
    <h2>Inputs</h2>

    <div class="form-grid">
      <label class="field">
        <span class="label">Signal (RSSI) (dBm)</span>
        <input id="sig" type="number" value="-62">
      </label>

      <label class="field">
        <span class="label">Noise Floor (dBm)</span>
        <input id="noise" type="number" value="-95">
      </label>

      <label class="field">
        <span class="label">Target SNR (dB)</span>
        <input id="target" type="number" value="25">
      </label>
    </div>

    <div class="actions">
      <button id="calc" class="btn btn-primary" type="button">Calculate</button>
      <button id="reset" class="btn" type="button">Reset</button>
      <a class="btn" href="/tools/wireless/">← Back to Wireless</a>
    </div>
  </section>

  <section class="card tool-card">
    <h2>Results</h2>
    <div id="results" class="results">
      <div class="muted">Enter values and press Calculate.</div>
    </div>
  </section>

  <section id="analysis-copy" class="card tool-card" style="display:none;"></section>

  <div id="continue-wrap" class="card" style="display:none;">
    <button id="continue" class="btn btn-primary" disabled type="button">
      Continue → Client Density
    </button>
  </div>
</main>

<script src="/assets/tool-flow.js"></script>
<script src="/assets/catalog.js"></script>
<script src="/assets/pipelines.js"></script>
<script src="/assets/pipeline.js"></script>
<script src="/assets/analyzer.js"></script>
<script src="./script.js?v=011"></script>

</body>
</html>




